---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import Stats from '../components/Stats.astro';

const services = [
  {
    icon: 'fas fa-cogs',
    title: 'Automatismos',
    desc: 'Sistemas de propulsión inteligente para accesos de alto tráfico, diseñados para durar.',
    specs: [
      { label: 'TORQUE', value: '350Nm' },
      { label: 'SPEED', value: '12m/min' },
      { label: 'DUTY CYCLE', value: '100%' },
    ],
    waText: 'Quiero información sobre automatismos para puertas',
    cotizaLabel: 'Cotizar Automatismos',
  },
  {
    icon: 'fas fa-microchip',
    title: 'Control Acceso',
    desc: 'Seguridad biométrica de grado empresarial integrada en su flujo de trabajo diario.',
    specs: [
      { label: 'AUTH', value: 'BIO / RFID' },
      { label: 'STORAGE', value: '50K USERS' },
      { label: 'INTERFACE', value: 'TCP/IP PoE' },
    ],
    waText: 'Quiero información sobre control de acceso',
    cotizaLabel: 'Cotizar Control de Acceso',
  },
  {
    icon: 'fas fa-road-barrier',
    title: 'Flujo Vehicular',
    desc: 'Gestión inteligente de tráfico con barreras de alta velocidad y sensores láser.',
    specs: [
      { label: 'OPEN TIME', value: '1.5s' },
      { label: 'ARM LENGTH', value: '6m MAX' },
      { label: 'ALGORITHM', value: 'LPR READY' },
    ],
    waText: 'Quiero información sobre barreras vehiculares',
    cotizaLabel: 'Cotizar Barreras',
  },
];
---

<BaseLayout canonical="https://puertasindusec.com">
  <Header currentPath="/" />
  <Hero />
  <script>
    document.querySelectorAll('.service-card').forEach(card => {
      card.addEventListener('mousemove', e => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--x', `${e.clientX - rect.left}px`);
        card.style.setProperty('--y', `${e.clientY - rect.top}px`);
      });
      card.addEventListener('click', () => card.classList.toggle('active'));
    });
  </script>

  <!-- Services Section -->
  <section class="py-40" id="servicios">
    <div class="max-w-[1280px] mx-auto px-8">
      <ScrollReveal>
        <div class="text-center mb-20">
          <span class="text-accent font-mono text-xs tracking-[3px] uppercase">Engineering Modules</span>
          <h2 class="font-display text-[clamp(2.5rem,5vw,4rem)] mt-4 text-white">Servicios de Vanguardia</h2>
          <p class="text-text-dim mt-6 max-w-[700px] mx-auto">
            Instalación profesional de motores, barreras vehiculares y control biométrico con marcas líderes y soporte técnico continuo.
          </p>
        </div>
      </ScrollReveal>
      <ScrollReveal stagger>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {services.map(s => (
            <div class="service-card bg-glass border border-glass-border rounded-3xl p-12 relative overflow-hidden transition-all duration-500 cursor-pointer hover:border-[rgba(41,151,255,0.3)] hover:-translate-y-1">
              <div class="text-4xl text-accent mb-8"><i class={s.icon}></i></div>
              <h3 class="font-display text-2xl tracking-wide mb-6 text-white">{s.title}</h3>
              <p class="text-text-dim text-sm mb-6">{s.desc}</p>
              <div class="service-card__extra">
                {s.specs.map(sp => (
                  <div class="flex justify-between font-mono text-xs text-status mb-2"><span>{sp.label}</span><span>{sp.value}</span></div>
                ))}
              </div>
              <a href={`https://wa.me/573178544089?text=${encodeURIComponent(s.waText)}`} target="_blank" class="text-[0.7rem] text-accent mt-4 inline-block no-underline">
                {s.cotizaLabel} <i class="fab fa-whatsapp"></i>
              </a>
            </div>
          ))}
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- About teaser -->
  <section class="bg-[#020202] py-20" id="empresa">
    <div class="max-w-[1280px] mx-auto px-8">
      <ScrollReveal>
        <div class="text-center" style="margin-bottom: 2rem;">
          <span class="text-accent font-mono text-xs tracking-[3px] uppercase">Core Identity</span>
          <h2 class="font-display text-[clamp(2.5rem,5vw,4rem)] mt-4 text-white">Diseñado para la<br />Excelencia</h2>
          <p class="text-text-dim mt-8 max-w-[600px] mx-auto">
            Ingeniería de precisión para entornos críticos. Conoce nuestra historia, equipo y marcas líderes.
          </p>
          <div class="mt-8">
            <a class="inline-flex items-center gap-3 px-8 py-4 rounded-pill font-semibold no-underline text-sm transition-all duration-300 bg-transparent border border-glass-border text-white hover:bg-glass hover:border-accent" href="/nosotros/">
              Conoce más sobre nosotros <i class="fas fa-arrow-right"></i>
            </a>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="bg-[#020202] py-40" id="por-que-elegirnos">
    <div class="max-w-[1280px] mx-auto px-8">
      <ScrollReveal>
        <div class="text-center mb-20">
          <span class="text-accent font-mono text-xs tracking-[3px] uppercase">Ventajas</span>
          <h2 class="font-display text-[clamp(2.5rem,5vw,4rem)] mt-4 text-white">Por Qué Elegirnos</h2>
        </div>
      </ScrollReveal>
      <ScrollReveal stagger>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="service-card bg-glass border border-glass-border rounded-3xl p-12 relative overflow-hidden transition-all duration-500" style="cursor: default;">
            <div class="text-4xl text-accent mb-8"><i class="fas fa-award"></i></div>
            <h3 class="font-display text-2xl tracking-wide mb-6 text-white">Calidad Garantizada</h3>
            <p class="text-text-dim text-sm">Trabajamos exclusivamente con marcas de prestigio internacional como LiftMaster, Shark, Dítec y AccessMatic. Cada equipo que instalamos cuenta con garantía de fábrica y certificación de calidad, asegurando un rendimiento óptimo y una larga vida útil en cada proyecto de automatización.</p>
          </div>
          <div class="service-card bg-glass border border-glass-border rounded-3xl p-12 relative overflow-hidden transition-all duration-500" style="cursor: default;">
            <div class="text-4xl text-accent mb-8"><i class="fas fa-headset"></i></div>
            <h3 class="font-display text-2xl tracking-wide mb-6 text-white">Soporte Técnico 24/7</h3>
            <p class="text-text-dim text-sm">Nuestro equipo de técnicos certificados está disponible las 24 horas del día, los 7 días de la semana, para atender cualquier eventualidad. Ofrecemos mantenimiento preventivo y correctivo con repuestos originales, minimizando el tiempo de inactividad de tus sistemas de acceso.</p>
          </div>
          <div class="service-card bg-glass border border-glass-border rounded-3xl p-12 relative overflow-hidden transition-all duration-500" style="cursor: default;">
            <div class="text-4xl text-accent mb-8"><i class="fas fa-ruler-combined"></i></div>
            <h3 class="font-display text-2xl tracking-wide mb-6 text-white">Soluciones a Medida</h3>
            <p class="text-text-dim text-sm">Cada proyecto es único. Realizamos un diagnóstico personalizado para diseñar la solución de automatización que mejor se adapte a tus necesidades y presupuesto. Desde puertas residenciales hasta barreras vehiculares industriales, creamos sistemas eficientes y duraderos. Te acompañamos desde la asesoría inicial hasta la puesta en marcha y el mantenimiento continuo de tu sistema de automatización.</p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- Stats Section -->
  <Stats />

  <!-- CTA Section -->
  <section class="py-40" id="contacto">
    <div class="max-w-[1280px] mx-auto px-8">
      <ScrollReveal type="scale">
        <div class="bg-gradient-to-br from-[#0a0a0a] to-black rounded-4xl py-24 px-16 text-center border border-glass-border relative overflow-hidden">
          <div class="absolute -top-[50px] -right-[50px] w-[200px] h-[200px] bg-[radial-gradient(circle,rgba(41,151,255,0.2)_0%,transparent_70%)]"></div>
          <h2 class="font-display text-[clamp(2.2rem,5vw,3.5rem)] mb-6 text-white">¿Listo para el próximo nivel?</h2>
          <p class="text-text-dim mb-12 max-w-[600px] mx-auto">
            Transformamos espacios ordinarios en entornos inteligentes de alta seguridad. Recibe una cotización personalizada sin compromiso con el respaldo de más de 10 años de experiencia.
          </p>
          <div class="flex gap-6 justify-center flex-wrap">
            <a class="inline-flex items-center gap-3 px-8 py-4 rounded-pill font-semibold no-underline text-sm transition-all duration-300 bg-white text-black hover:-translate-y-0.5" href="https://wa.me/573178544089" target="_blank">
              Hablar con un Experto
            </a>
            <a class="inline-flex items-center gap-3 px-8 py-4 rounded-pill font-semibold no-underline text-sm transition-all duration-300 bg-transparent border border-glass-border text-white hover:bg-glass hover:border-accent" href="/productos/">
              Ver Catálogo Tech
            </a>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <Footer />
  <script is:inline src="/scripts/main.js"></script>
</BaseLayout>
