          <div class="module-inner">
            <div class="absolute top-0 left-1/2 w-0.5 h-full bg-[rgba(41,151,255,0.1)]" style="width:2px;"></div>
            <div class="absolute left-0 top-1/2 w-full h-0.5 bg-[rgba(41,151,255,0.1)]"></div>
