---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { Image } from 'astro:assets';

import p3 from '../assets/images/proyecto_3.webp';
import p4 from '../assets/images/proyecto_4.webp';
import p5 from '../assets/images/proyecto_5.webp';
import p6 from '../assets/images/proyecto_6.webp';
import p7 from '../assets/images/proyecto_7.webp';
import p8 from '../assets/images/proyecto_8.webp';
import p9 from '../assets/images/proyecto_9.webp';
import p11 from '../assets/images/proyecto_11.webp';

const projects = [
  {
    image: p3,
    imageAlt: 'Motor de garaje Shark 1000 instalado',
    overlay: 'Automatismo de Garaje',
    title: 'Motor Shark 1000 para Garaje',
    desc: 'Instalación de motor de techo Shark 1000 para puerta de garaje. Sistema silencioso con apertura rápida y luz LED integrada.',
    specs: [
      { label: 'Equipo', value: 'Shark 1000' },
      { label: 'Tipo', value: 'Garaje' },
    ],
    waText: 'Información sobre motor Shark 1000 para garaje',
  },
  {
    image: p4,
    imageAlt: 'Portón metálico con paneles de madera',
    overlay: 'Puertas Residenciales',
    title: 'Portón Metálico con Acabado en Madera',
    desc: 'Fabricación e instalación de portón batiente y puerta peatonal en estructura metálica con paneles de madera natural.',
    specs: [
      { label: 'Material', value: 'Metal + Madera' },
      { label: 'Tipo', value: 'Batiente' },
    ],
    waText: 'Información sobre portones con acabado en madera',
  },
  {
    image: p5,
    imageAlt: 'Construcción de estructura para garaje',
    overlay: 'Obra Civil',
    title: 'Construcción de Estructura para Garaje',
    desc: 'Obra de construcción de estructura metálica con cubierta para garaje residencial, preparada para automatización posterior.',
    specs: [
      { label: 'Ubicación', value: 'Residencial' },
      { label: 'Tipo', value: 'Estructura' },
    ],
    waText: 'Información sobre construcción de garajes',
  },
  {
    image: p6,
    imageAlt: 'Puerta de seguridad con cerradura multipunto',
    overlay: 'Seguridad',
    title: 'Puerta de Seguridad Multipunto',
    desc: 'Instalación de puerta de seguridad interior con acabado en madera y sistema de cerradura multipunto de alta resistencia.',
    specs: [
      { label: 'Cerradura', value: 'Multipunto' },
      { label: 'Tipo', value: 'Seguridad' },
    ],
    waText: 'Información sobre puertas de seguridad',
  },
  {
    image: p7,
    imageAlt: 'Barrera vehicular Dítec QIK',
    overlay: 'Barrera Vehicular',
    title: 'Barrera Vehicular Dítec QIK',
    desc: 'Barrera vehicular profesional Dítec QIK de alta velocidad con iluminación LED integrada. Ideal para parkings y conjuntos.',
    specs: [
      { label: 'Marca', value: 'Dítec' },
      { label: 'Tipo', value: 'QIK Pro' },
    ],
    waText: 'Información sobre barreras vehiculares Dítec',
  },
  {
    image: p8,
    imageAlt: 'Motor industrial AccessMatic',
    overlay: 'Motor Industrial',
    title: 'Motor Industrial AccessMatic',
    desc: 'Motor de cortina enrollable AccessMatic con sistema de engranajes de alta resistencia para uso industrial pesado.',
    specs: [
      { label: 'Marca', value: 'AccessMatic' },
      { label: 'Tipo', value: 'Cortina Enrollable' },
    ],
    waText: 'Información sobre motores industriales AccessMatic',
  },
  {
    image: p9,
    imageAlt: 'Control remoto LiftMaster 891LM',
    overlay: 'Control Remoto',
    title: 'Control Remoto LiftMaster 891LM',
    desc: 'Control remoto de un botón LiftMaster 891LM con tecnología Security+ 2.0 y frecuencia rolling code para máxima seguridad.',
    specs: [
      { label: 'Marca', value: 'LiftMaster' },
      { label: 'Modelo', value: '891LM' },
    ],
    waText: 'Información sobre controles LiftMaster',
  },
  {
    image: p11,
    imageAlt: 'Puerta batiente automatizada en conjunto residencial',
    overlay: 'Automatismo Residencial',
    title: 'Automatización de Puerta Batiente',
    desc: 'Instalación de motor para puerta batiente metálica en conjunto residencial. Sistema con brazo electromecánico de alta durabilidad.',
    specs: [
      { label: 'Ubicación', value: 'Conjunto' },
      { label: 'Tipo', value: 'Batiente' },
    ],
    waText: 'Información sobre automatización de puertas batientes',
  },
];
---

<BaseLayout
  title="Proyectos"
  description="Portafolio de proyectos de automatización, puertas automáticas y control de acceso realizados por INDUSEC en Bogotá."
  canonical="https://puertasindusec.com/proyectos/"
>
  <Header currentPath="/proyectos/" />

  <section class="pt-40 pb-40" id="proyectos">
    <div class="max-w-[1280px] mx-auto px-8">
      <ScrollReveal>
        <div class="text-center mb-20">
          <span class="text-accent font-mono text-xs tracking-[3px] uppercase">Portafolio</span>
          <h1 class="font-display text-[clamp(2.5rem,5vw,4rem)] mt-4 text-white">Nuestros Proyectos</h1>
          <p class="text-text-dim mt-4">Soluciones de automatización implementadas en residencias, empresas y espacios industriales en Bogotá.</p>
        </div>
      </ScrollReveal>

      <ScrollReveal stagger>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {projects.map(p => (
            <div class="group bg-glass border border-glass-border rounded-[20px] overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:border-accent hover:shadow-[0_15px_40px_rgba(41,151,255,0.1)]">
              <div class="aspect-[16/10] relative overflow-hidden">
                <Image src={p.image} alt={p.imageAlt} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                <div class="absolute top-4 right-4 bg-black/80 px-4 py-2 rounded-full font-mono text-xs text-accent backdrop-blur">{p.overlay}</div>
              </div>
              <div class="p-6">
                <h3 class="font-display text-xl tracking-wide mb-3 text-white">{p.title}</h3>
                <p class="text-text-dim text-sm mb-4">{p.desc}</p>
                <div class="grid grid-cols-2 gap-3 mb-4">
                  {p.specs.map(s => (
                    <div class="flex flex-col gap-1">
                      <span class="font-mono text-[0.65rem] text-text-dim">{s.label}</span>
                      <span class="font-mono text-xs text-accent">{s.value}</span>
                    </div>
                  ))}
                </div>
              </div>
              <div class="px-6 py-4 border-t border-glass-border">
                <a href={`https://wa.me/573178544089?text=${encodeURIComponent(p.waText)}`} target="_blank" class="inline-flex items-center gap-3 px-5 py-[0.7rem] rounded-pill font-semibold no-underline text-xs transition-all duration-300 bg-transparent border border-glass-border text-white hover:bg-glass hover:border-accent">
                  <i class="fab fa-whatsapp"></i> Consultar
                </a>
              </div>
            </div>
          ))}
        </div>
      </ScrollReveal>

      <ScrollReveal>
        <div class="text-center mt-16">
          <p class="text-text-dim mb-4">¿Tienes un proyecto en mente?</p>
          <a href="https://wa.me/573178544089?text=Hola,%20me%20gustaría%20cotizar%20un%20proyecto." target="_blank" class="inline-flex items-center gap-3 px-8 py-4 rounded-pill font-semibold no-underline text-sm transition-all duration-300 bg-accent text-white hover:-translate-y-0.5 hover:shadow-[0_10px_20px_rgba(41,151,255,0.3)]">
            <i class="fab fa-whatsapp"></i> Cotizar Proyecto
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <Footer />
  <script is:inline src="/scripts/main.js"></script>
</BaseLayout>
