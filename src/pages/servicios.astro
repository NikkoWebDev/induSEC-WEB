---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';

const services = [
  {
    icon: 'fas fa-tools',
    title: 'Instalación y Puesta en Marcha',
    desc: 'Instalamos motores para puertas batientes, corredizas, barreras vehiculares y todo tipo de automatismos con garantía de fábrica y mano de obra calificada.',
    specs: [
      { label: 'Puertas batientes', value: '✓' },
      { label: 'Portones corredizos', value: '✓' },
      { label: 'Barreras vehiculares', value: '✓' },
      { label: 'Garantía incluida', value: '✓' },
    ],
    waText: 'Quiero cotizar instalación de automatismos',
    cotizaLabel: 'Cotizar Instalación',
  },
  {
    icon: 'fas fa-wrench',
    title: 'Mantenimiento y Reparación',
    desc: 'Planes de mantenimiento preventivo para prolongar la vida útil de tus equipos. Servicio de reparación rápido y efectivo.',
    specs: [
      { label: 'Mantenimiento preventivo', value: '✓' },
      { label: 'Reparación express', value: '✓' },
      { label: 'Diagnóstico técnico', value: '✓' },
      { label: 'Repuestos originales', value: '✓' },
    ],
    waText: 'Quiero información sobre mantenimiento',
    cotizaLabel: 'Cotizar Mantenimiento',
  },
  {
    icon: 'fas fa-fingerprint',
    title: 'Sistemas de Control de Acceso',
    desc: 'Implementación de control de accesos biométrico, por tarjeta de proximidad, teclado y sistemas inteligentes para gestionar el flujo de personas y vehículos.',
    specs: [
      { label: 'Control biométrico', value: '✓' },
      { label: 'Tarjetas RFID', value: '✓' },
      { label: 'Teclados codificados', value: '✓' },
      { label: 'Software de gestión', value: '✓' },
    ],
    waText: 'Quiero información sobre control de acceso',
    cotizaLabel: 'Cotizar Control de Acceso',
  },
];
---

<BaseLayout
  title="Servicios"
  description="Servicios de instalación, mantenimiento y reparación de puertas automáticas, control de acceso y barreras vehiculares por INDUSEC en Bogotá."
  canonical="https://puertasindusec.com/servicios/"
>
  <Header currentPath="/servicios/" />

  <section class="pt-40 pb-40" id="servicios">
    <div class="max-w-[1280px] mx-auto px-8">
      <ScrollReveal>
        <div class="text-center mb-20">
          <span class="text-accent font-mono text-xs tracking-[3px] uppercase">Servicios</span>
          <h1 class="font-display text-[clamp(2.5rem,5vw,4rem)] mt-4 text-white">Soluciones Integrales</h1>
          <p class="text-text-dim mt-4">Desde la instalación hasta el mantenimiento, garantizamos el funcionamiento óptimo de tus sistemas automáticos. Trabajamos con marcas líderes como LiftMaster, Shark, Dítec y AccessMatic, y nuestros técnicos certificados realizan cada intervención siguiendo las normas eléctricas colombianas vigentes. Ofrecemos asesoría técnica gratuita para ayudarte a elegir la solución adecuada para tu proyecto, ya sea residencial, comercial o industrial.</p>
        </div>
      </ScrollReveal>

      <ScrollReveal stagger>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {services.map(s => (
            <div class="service-card bg-glass border border-glass-border rounded-3xl p-12 relative overflow-hidden transition-all duration-500 hover:border-[rgba(41,151,255,0.3)] hover:-translate-y-1">
              <div class="text-4xl text-accent mb-8"><i class={s.icon}></i></div>
              <h3 class="font-display text-2xl tracking-wide mb-6 text-white">{s.title}</h3>
              <p class="text-text-dim text-sm mb-6">{s.desc}</p>
              <div class="service-card__extra" style="max-height:200px;opacity:1;padding-top:1.5rem;margin-top:1rem;">
                {s.specs.map(sp => (
                  <div class="flex justify-between font-mono text-xs text-status mb-2"><span>{sp.label}</span><span>{sp.value}</span></div>
                ))}
              </div>
              <a href={`https://wa.me/573178544089?text=${encodeURIComponent(s.waText)}`} target="_blank" class="text-[0.7rem] text-accent mt-4 inline-block no-underline">
                {s.cotizaLabel} <i class="fab fa-whatsapp"></i>
              </a>
            </div>
          ))}
        </div>
      </ScrollReveal>

      <ScrollReveal>
        <div class="faq-section" style="margin-top: 6rem;">
          <div class="text-center mb-20">
            <span class="text-accent font-mono text-xs tracking-[3px] uppercase">FAQ</span>
            <h2 class="font-display text-[clamp(2.5rem,5vw,4rem)] mt-4 text-white">Preguntas Frecuentes</h2>
          </div>
          <div class="max-w-[700px] mx-auto mt-12">
            <details class="faq-item">
              <summary class="faq-question">¿Cuánto cuesta instalar un motor para puerta batiente?</summary>
              <div class="faq-answer">El precio varía según el tipo de motor, el peso de la puerta y la complejidad de la instalación. Ofrecemos cotización personalizada sin compromiso. Contáctanos por WhatsApp para recibir una evaluación gratuita de tu proyecto.</div>
            </details>
            <details class="faq-item">
              <summary class="faq-question">¿Qué mantenimiento necesita una barrera vehicular?</summary>
              <div class="faq-answer">Recomendamos mantenimiento preventivo cada 6 meses que incluye lubricación de componentes, revisión del sistema eléctrico, ajuste de sensores y verificación de la batería de respaldo. Ofrecemos planes de mantenimiento programado para evitar fallos inesperados.</div>
            </details>
            <details class="faq-item">
              <summary class="faq-question">¿En qué zonas de Bogotá trabajan?</summary>
              <div class="faq-answer">Realizamos instalaciones y mantenimiento en toda Bogotá y municipios cercanos como Soacha, Chía, Cajicá, Mosquera y Funza. No importa dónde estés, nuestro equipo se desplaza hasta tu ubicación.</div>
            </details>
            <details class="faq-item">
              <summary class="faq-question">¿Ofrecen garantía en sus instalaciones?</summary>
              <div class="faq-answer">Sí, todos nuestros trabajos incluyen garantía de fábrica en los equipos más garantía por escrito en la mano de obra. Entregamos certificación de instalación y manuales de usuario para tu tranquilidad.</div>
            </details>
            <details class="faq-item">
              <summary class="faq-question">¿Cuánto tiempo toma una instalación típica?</summary>
              <div class="faq-answer">Una instalación estándar de motor para puerta batiente o barrera vehicular toma entre 4 y 8 horas, dependiendo de la complejidad. Proyectos más grandes como sistemas biométricos completos pueden tomar 1 o 2 días.</div>
            </details>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal>
        <div class="text-center mt-16">
          <p class="text-text-dim mb-4">¿Quieres cotizar nuestros servicios?</p>
          <a href="https://wa.me/573178544089?text=Hola,%20me%20interesan%20sus%20servicios." target="_blank" class="inline-flex items-center gap-3 px-8 py-4 rounded-pill font-semibold no-underline text-sm transition-all duration-300 bg-accent text-white hover:-translate-y-0.5 hover:shadow-[0_10px_20px_rgba(41,151,255,0.3)]">
            <i class="fab fa-whatsapp"></i> Contáctanos
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <Footer />
  <script is:inline src="/scripts/main.js"></script>
</BaseLayout>
