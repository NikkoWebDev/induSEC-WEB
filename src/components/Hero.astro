        </div>
        <h1 class="hero-anim hero-anim--2 font-display text-[clamp(3.5rem,8vw,6rem)] leading-[0.95] font-extrabold mb-8 uppercase">
          <span class="block bg-gradient-to-b from-white to-[#888] bg-clip-text text-transparent">Automatización</span>
          <span class="block text-accent">Industrial</span>
          <span class="block bg-gradient-to-b from-white to-[#888] bg-clip-text text-transparent">a Medida</span>
