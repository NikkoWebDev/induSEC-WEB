    <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_0.8fr] gap-16 items-center">
      <div>
        <div class="hero-anim hero-anim--1 inline-flex items-center gap-2 text-status font-mono text-xs mb-6">
          <span class="w-2 h-2 rounded-full bg-status shadow-[0_0_10px_#10b981] animate-pulse-dot"></span>
