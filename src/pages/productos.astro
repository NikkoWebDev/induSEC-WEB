---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';

const products = [
  { icon: 'fas fa-door-open', title: 'Motores Batientes', desc: 'Ideal para puertas de dos hojas. Resistencia y ciclos de trabajo intensivo.', tag: 'Automatismos', tagClass: 'tag--blue' },
  { icon: 'fas fa-road-barrier', title: 'Barreras Vehiculares', desc: 'Control de acceso rápido y seguro para parkings y áreas industriales.', tag: 'Parking', tagClass: 'tag--green' },
  { icon: 'fas fa-fingerprint', title: 'Control Biométrico', desc: 'Sistemas avanzados de huella dactilar para alta seguridad y registro de personal.', tag: 'Seguridad', tagClass: 'tag--orange' },
  { icon: 'fas fa-satellite-dish', title: 'Receptoras y Mandos', desc: 'Kits completos de control remoto y receptores de largo alcance y alta fiabilidad.', tag: 'Accesorios', tagClass: 'tag--steel' },
  { icon: 'fas fa-arrows-alt-h', title: 'Motores Corredizos', desc: 'Potentes motores para portones corredizos pesados, residenciales e industriales.', tag: 'Automatismos', tagClass: 'tag--blue' },
  { icon: 'fas fa-bolt', title: 'Cercas Eléctricas', desc: 'Sistemas perimetrales de alta tensión para protección de propiedades.', tag: 'Seguridad', tagClass: 'tag--orange' },
  { icon: 'fas fa-traffic-light', title: 'Semáforos y Balizas', desc: 'Indicadores de tráfico y seguridad para entradas y salidas automáticas.', tag: 'Señalización', tagClass: 'tag--green' },
  { icon: 'fas fa-id-card', title: 'Sistemas RFID', desc: 'Lectores de tarjetas y tags para gestión eficiente de flotas y personal.', tag: 'Control Acceso', tagClass: 'tag--blue' },
];
---

<BaseLayout
  title="Productos"
  description="Catálogo de productos de automatización: motores, barreras vehiculares, control biométrico, cercas eléctricas y más por INDUSEC en Bogotá."
  canonical="https://puertasindusec.com/productos/"
>
  <Header currentPath="/productos/" />

  <section class="section section--first" id="productos">
    <div class="container">
      <ScrollReveal>
        <div class="section-header">
          <span class="section-label">Catálogo</span>
          <h1 class="section-title">Productos de Automatismo</h1>
          <p style="color: var(--text-dim); margin-top: 1rem;">Equipos de automatización, control de acceso y seguridad con la mejor tecnología del mercado.</p>
        </div>
      </ScrollReveal>

      <ScrollReveal stagger>
        <div class="products-grid">
          {products.map(p => (
            <div class="product-card">
              <div class="product-card__img"><i class={p.icon}></i></div>
              <div class="product-card__body">
                <h3 class="product-card__title">{p.title}</h3>
                <p class="product-card__desc">{p.desc}</p>
              </div>
              <div class="product-card__footer">
                <span class={`tag ${p.tagClass}`}>{p.tag}</span>
                <a href={`https://wa.me/573178544089?text=${encodeURIComponent('Información sobre ' + p.title)}`} target="_blank" class="btn btn--outline btn--sm"><i class="fab fa-whatsapp"></i></a>
              </div>
            </div>
          ))}
        </div>
      </ScrollReveal>

      <ScrollReveal>
        <div class="text-center mt-60 cta-servicios">
          <p style="color: var(--text-dim); margin-bottom: 1rem;">¿No encuentras lo que buscas?</p>
          <a href="https://wa.me/573178544089?text=Hola,%20me%20interesa%20cotizar%20un%20producto%20específico." target="_blank" class="btn btn--primary">
            <i class="fab fa-whatsapp"></i> Contáctanos
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <Footer />
  <script is:inline src="/scripts/main.js"></script>
</BaseLayout>
